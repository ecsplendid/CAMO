--[[--
MARPAT / MultiCam Camouflage Generator for DaVinci Resolve Fusion
Generates MARPAT-style digital camouflage or MultiCam-style organic camouflage
using 3D simplex noise with fBm. All parameters are keyframeable.
Uses grid-cell caching for performance. Frame caching skips re-render when
parameters haven't changed. Pixel fill uses DoMultiProcess for multi-threaded
scanline rendering across CPU cores (4-8x speedup).

Install: Copy to ~/Library/Application Support/Blackmagic Design/DaVinci Resolve/Fusion/Fuses/
--]]--

FuRegisterClass("MARPATCamo", CT_SourceTool, {
    REGS_Name = "MARPAT Camo",
    REGS_Category = "Generator",
    REGS_OpIconString = "MCG",
    REGS_OpDescription = "Generates MARPAT-style digital or MultiCam organic camouflage textures",
    REG_NoObjMatCtrls = true,
    REG_NoMotionBlurCtrls = true,
    REG_Source_GlobalCtrls = true,
    REG_Source_SizeCtrls = true,
    REG_Source_AspectCtrls = true,
    REG_Source_DepthCtrls = true,
    REG_TimeVariant = true,
    REGS_Company = "MLST",
    REG_Version = 400,
})

